{
    "name": "hotreloadstudios/triage",
    "description": "A self-hosted customer support ticketing system for Laravel.",
    "keywords": [
        "laravel",
        "triage",
        "support",
        "tickets"
    ],
    "homepage": "https://github.com/tyrailleverett/triage",
    "license": "MIT",
    "authors": [
        {
            "name": "Hot Reload Studios",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "beyondcode/laravel-mailbox": "^5.0",
        "illuminate/contracts": "^11.0||^12.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/boost": "^2.1",
        "laravel/pint": "^1.24",
        "nunomaduro/collision": "^8.8",
        "orchestra/testbench": "^10.0.0||^9.0.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "rector/rector": "^2.3",
        "spatie/laravel-ray": "^1.35",
        "tightenco/duster": "^3.3"
    },
    "autoload": {
        "psr-4": {
            "HotReloadStudios\\Triage\\": "src/",
            "HotReloadStudios\\Triage\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "HotReloadStudios\\Triage\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "lint": [
            "./vendor/bin/duster fix",
            "./vendor/bin/rector"
        ],
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "HotReloadStudios\\Triage\\TriageServiceProvider"
            ],
            "aliases": {
                "Triage": "HotReloadStudios\\Triage\\Facades\\Triage"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
